---
import '../styles/global.css';
import { HiCode, HiOutlineCubeTransparent, HiStar, HiTag } from 'react-icons/hi';
import { TagScroller } from '../components/TagScroller';
import { siteSettings } from '../data/site-settings';
import { getGitHubRepositoryCards } from '../lib/github-repositories';

const projectsResult = await getGitHubRepositoryCards();
const projects = projectsResult.repositories;
const isGitHubUnavailable = !projectsResult.isAvailable;

const pageMaxWidthClass = 'max-w-3xl';
const projectGridClass = 'grid-cols-1';

const formatStars = (stars: number | null | undefined): string => {
  if (typeof stars !== 'number') {
    return '-';
  }

  return new Intl.NumberFormat('en', {
    notation: stars >= 1000 ? 'compact' : 'standard',
    maximumFractionDigits: 1,
  }).format(stars);
};

const formatLatestTag = (tag: string | null | undefined): string => tag ?? '-';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="A showroom for open source software published by Craft Guild."
    />
    <title>{siteSettings.headerLabel}</title>
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-800 antialiased">
    <main class="min-h-screen px-6">
      <div class:list={['mx-auto flex min-h-screen w-full flex-col', pageMaxWidthClass]}>
        <header class="py-16 text-center">
          <h1 id="page-title" class="text-3xl font-bold tracking-normal sm:text-4xl">
            {siteSettings.headerLabel}
          </h1>
        </header>

        <section class="flex-1 py-0" aria-labelledby="page-title">
          {
            isGitHubUnavailable ? (
              <div class="flex flex-col items-center gap-4 py-16 text-center text-slate-400">
                <HiOutlineCubeTransparent className="size-20" aria-hidden="true" />
                <div class="flex flex-col gap-1 text-sm leading-5">
                  <p>GitHub repository data is temporarily unavailable</p>
                  <p>Please visit again later</p>
                </div>
                {
                  projectsResult.errorMessage && (
                    <p class="max-w-xl break-words text-sm leading-5 text-slate-400">
                      {projectsResult.errorMessage}
                    </p>
                  )
                }
              </div>
            ) : (
              <div class:list={['grid items-start gap-5', projectGridClass]}>
                {
                  projects.map((project) => (
                    <a
                      href={project.link}
                      data-repository={new URL(project.link).pathname.slice(1)}
                      target="_blank"
                      rel="noreferrer"
                      class="flex flex-col gap-8 rounded-lg bg-white px-6 py-5 shadow-sm transition-shadow duration-200 hover:shadow-md focus:outline-none"
                    >
                      <article class="contents">
                        <div class="flex flex-col gap-4">
                          <div class="flex flex-col gap-1">
                        <h2 class="text-2xl font-semibold text-slate-800">
                          {project.shortName}
                        </h2>
                            <p class="break-all text-sm leading-6 text-slate-400">
                              {project.link}
                            </p>
                          </div>
                          <p class="text-sm leading-6 text-slate-800">
                            {project.summary}
                          </p>
                        </div>
                    <div class="flex items-center gap-2">
                      <div class="flex shrink-0 items-center gap-3">
                        <ul class="flex items-center gap-2" aria-label={`${project.name} languages`}>
                          <li class="flex h-6 items-center">
                            {
                              project.languageIcon ? (
                                <svg
                                  viewBox="0 0 24 24"
                                  role="img"
                                  aria-label={project.languageIcon.title}
                                  class="size-4"
                                  style={`fill: #${project.languageIcon.hex}`}
                                >
                                  <path d={project.languageIcon.path} />
                                </svg>
                              ) : (
                                <HiCode className="size-4 text-slate-400" aria-label="Code" />
                              )
                            }
                          </li>
                        </ul>
                        {
                          project.tags.length > 0 && (
                            <span class="h-5 w-px bg-slate-200" aria-hidden="true" />
                          )
                        }
                      </div>
                      <div class="relative ml-0 min-w-0 flex-1">
                        <TagScroller
                          label={`${project.name} tags`}
                          tags={project.tags}
                          client:load
                        />
                      </div>
                      <p
                            class="flex h-6 shrink-0 items-center gap-3 text-xs font-medium leading-none text-slate-400"
                            aria-label={`${project.name} latest tag and GitHub stars`}
                          >
                            <span class="flex items-center">
                              <HiTag className="mr-1 size-4" aria-hidden="true" />
                              {formatLatestTag(project.latestTag)}
                            </span>
                            <span class="flex items-center">
                              <HiStar className="mr-1 size-4" aria-hidden="true" />
                              {formatStars(project.stars)}
                            </span>
                          </p>
                        </div>
                      </article>
                    </a>
                  ))
                }
              </div>
            )
          }
        </section>

        <footer class="py-16 text-center text-sm text-slate-800">
          <a
            href={siteSettings.footerUrl}
            target="_blank"
            rel="noreferrer"
            class="transition-opacity duration-200 hover:opacity-75 focus:outline-none"
          >
            {siteSettings.footerLabel}
          </a>
        </footer>
      </div>
    </main>
  </body>
</html>
